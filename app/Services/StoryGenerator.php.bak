    public function generateInitialStory($userName, $gender, $genre, $location)
    {
        $initialData = $this->getInitialPlot($genre, $location);
        
        $aiContent = $this->expandWithAI($initialData['content'], [
            'userName' => $userName,
            'gender' => $gender,
            'genre' => $genre,
            'location' => $location
        ]);

        return [
            'content' => $aiContent,
            'choices' => $initialData['choices'],
            'is_ending' => false,
            'image' => $initialData['image'] ?? 'wallpaperhorror.jpeg'
        ];
    }

    public function generateNextSegment($previousStory, $choiceText, $currentStep, $maxSteps = 5, $genre = 'Horror', $location = 'Pendakian')
    {
        $nodes = $this->getStoryNodes($genre, $location);
        $normalizedChoice = trim($choiceText);

        if (isset($nodes[$normalizedChoice])) {
            $plotPoint = $nodes[$normalizedChoice]['content'];
            $aiContent = $this->expandWithAI($plotPoint, [
                'previousStory' => $previousStory,
                'choice' => $normalizedChoice,
                'genre' => $genre,
                'location' => $location
            ]);

            return [
                'content' => $aiContent,
                'choices' => $nodes[$normalizedChoice]['choices'],
                'is_ending' => $nodes[$normalizedChoice]['is_ending'],
                'image' => $nodes[$normalizedChoice]['image'] ?? 'wallpaperhorror.jpeg'
            ];
        }

        return [
            'content' => "Kisahmu telah mencapai garis akhir secara misterius. Petualangan telah selesai.",
            'choices' => [],
            'is_ending' => true,
            'image' => 'wallpaperhorror.jpeg'
        ];
    }

    protected function expandWithAI($plotPoint, $contextData = [])
    {
        $context = "";
        if (!empty($contextData['userName'])) {
            $context .= "Tokoh utama adalah {$contextData['userName']} ({$contextData['gender']}). ";
        }
        if (!empty($contextData['previousStory'])) {
            $shortPrev = mb_substr(trim($contextData['previousStory']), -800);
            $context .= "Cerita sebelumnya: \"{$shortPrev}\". Tokoh memilih opsi: \"{$contextData['choice']}\". ";
        }

        $prompt = "Kamu adalah penulis buku cerita anak-anak bergaya horor ringan dalam bahasa Indonesia. {$context} Tulis ulang plot berikut dengan gaya BUKU CERITA ANAK: kalimat pendek dan sederhana, ada dialog antar tokoh dengan tanda kutip, pisahkan setiap adegan menjadi paragraf baru, gunakan kata-kata yang mudah dipahami anak SD. Panjang: 3-4 paragraf pendek. Plot dasar: \"{$plotPoint}\". HANYA outputkan teks ceritanya saja, tanpa judul, tanpa opsi pilihan, tanpa salam pembuka.";

        try {
            // Coba Hugging Face dengan model Zephyr yang lebih stabil untuk Free API
            $response = Http::withToken($this->apiKey)
                ->timeout(15)
                ->post("https://api-inference.huggingface.co/models/HuggingFaceH4/zephyr-7b-beta", [
                    'inputs' => "<|system|>\nKamu adalah penulis cerita petualangan anak dan horor ringan yang memakai bahasa gaul sehari-hari yang mudah dimengerti.<|end|>\n<|user|>\n{$prompt}<|end|>\n<|assistant|>\n",
                    'parameters' => [
                        'max_new_tokens' => 200,
                        'return_full_text' => false,
                        'temperature' => 0.8,
                        'top_p' => 0.9,
                        'do_sample' => true
                    ]
                ]);

            if ($response->successful()) {
                $result = $response->json();
                $text = $result[0]['generated_text'] ?? '';
                $text = trim(preg_replace('/^"|"$/', '', $text));
                if (!empty($text)) {
                    return $text;
                }
            }

            Log::warning("HF failed: " . substr($response->body(), 0, 200));
        } catch (\Exception $e) {
            Log::warning("HF exception: " . $e->getMessage());
        }

        // Fallback ke Pollinations dengan Retry Mechanism (untuk mengatasi Queue Full 429)
        $maxRetries = 4;
        for ($i = 0; $i < $maxRetries; $i++) {
            try {
                $seed = rand(1, 999999);
                $response = Http::timeout(30)
                    ->withHeaders(['Content-Type' => 'application/json'])
                    ->post("https://text.pollinations.ai/openai", [
                        'messages' => [
                            ['role' => 'system', 'content' => 'Anda adalah pendongeng dengan gaya bahasa yang sangat sederhana, gampang dimengerti semua umur, dan tidak memakai kata-kata kiasan yang susah.'],
                            ['role' => 'user', 'content' => $prompt]
                        ],
                        'model' => 'openai',
                        'seed' => $seed,
                        'jsonMode' => false
                    ]);
                
                if ($response->successful()) {
                    $result = $response->json();
                    $text = $result['choices'][0]['message']['content'] ?? '';
                    $text = trim(preg_replace('/^"|"$/', '', $text));
                    if (!empty($text)) {
                        return $text;
                    }
                } elseif ($response->status() === 429) {
                    // Jika queue penuh, tunggu 2-3 detik lalu coba lagi
                    sleep(rand(2, 3));
                    continue;
                } else {
                    Log::warning("Pollinations failed (Status {$response->status()}): " . substr($response->body(), 0, 200));
                    break;
                }
            } catch (\Exception $e) {
                Log::warning("Pollinations exception (Retry {$i}): " . $e->getMessage());
                sleep(2);
            }
        }

        // Jika semua AI gagal, gunakan plot dasar sebagai fallback
        return $plotPoint;
    }
}
