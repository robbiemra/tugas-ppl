                    ],
                    'is_ending' => false
                ],
                'Masuk kamar mayat' => [
                    'content' => "Kamu nekat masuk. Ada seorang suster berbaju kotor sedang membelakangimu. Waktu dia menoleh, ternyata wajahnya rata tanpa mata dan mulut!",
                    'choices' => [
                        ['choice_text' => 'Pura-pura mati'],
